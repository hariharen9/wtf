#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawn } = require('child_process');

const isWindows = process.platform === 'win32';
const binaryName = isWindows ? 'wtf.exe' : 'wtf';
const binaryPath = path.join(__dirname, binaryName);

if (!fs.existsSync(binaryPath)) {
  console.error(`❌ WTF binary is missing from: ${binaryPath}`);
  console.error('   Please run "npm rebuild wtf-cli" or build it manually in the package folder: "go build -o bin/wtf main.go"');
  process.exit(1);
}

// Forward all CLI arguments, pipes, and exit codes
const args = process.argv.slice(2);
const child = spawn(binaryPath, args, { stdio: 'inherit' });

child.on('close', (code) => {
  process.exit(code === null ? 0 : code);
});

child.on('error', (err) => {
  console.error(`❌ Failed to launch WTF binary: ${err.message}`);
  process.exit(1);
});
